# SpendSense environment variables
# Copy to `.env` and fill in values. Expo loads these automatically.
# Only EXPO_PUBLIC_* vars are embedded in the app — never put secrets there.

# ── App environment ──────────────────────────────────────────────────────────
# development | preview | production
EXPO_PUBLIC_APP_ENV=development

# ── EAS (Expo Application Services) ──────────────────────────────────────────
# Required once you run `eas init` / `eas build`. Find in expo.dev project settings.
# Used by EAS CLI locally — NOT read by the app at runtime.
EAS_PROJECT_ID=

# Personal access token for CI/CD (`eas build`, GitHub Actions). Keep secret.
# Create at: https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_TOKEN=

# ── OCR (optional — V1 fallback server, not wired yet) ───────────────────────
# On-device ML Kit is the primary path. These are for an optional server fallback
# described in CLAUDE.md. Leave blank until you implement server OCR in lib/ocr.ts.
EXPO_PUBLIC_OCR_API_URL=
EXPO_PUBLIC_OCR_API_KEY=

# Set to "true" while lib/ocr.ts is still mocked (current default behavior)
EXPO_PUBLIC_USE_MOCK_OCR=true

# ── Future AI layer (V2+ — not implemented) ──────────────────────────────────
# EXPO_PUBLIC_AI_API_URL=
# EXPO_PUBLIC_AI_API_KEY=
